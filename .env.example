# Copy to .env for local development (auto-loaded via godotenv).
# Every var is consumed by internal/infra/config (caarlos0/env).

# --- app ---
APP_ENV=local
APP_LOG_LEVEL=info
APP_HTTP_ADDR=:8080
APP_GRPC_ADDR=:9090
APP_GRPC_HEALTH_ADDR=:9091
APP_WORKER_HEALTH_ADDR=:8081
APP_SWAGGER_ENABLED=true
APP_PPROF_ENABLED=true
APP_START_TIMEOUT=30s
APP_STOP_TIMEOUT=30s

# --- postgres (the wired backend; gorm) ---
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/app?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m
POSTGRES_MIGRATE=true
POSTGRES_MIGRATE_VERSION=0

# --- mongo (replica set required for transactions) ---
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DATABASE=app

# --- redis (cache / lock / limiter) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# --- kafka (worker) ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=account.events
KAFKA_GROUP_ID=account-worker

# --- worker loop / lock ---
WORKER_INTERVAL=30s
WORKER_LOCK_TTL=1m
WORKER_LOCK_KEY=worker:housekeeping

# --- tracing (OpenTelemetry) — leave endpoint empty to disable export ---
OTEL_SERVICE_NAME=go-clean-arch-template
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLE_RATIO=1.0
OTEL_EXPORTER_INSECURE=true
